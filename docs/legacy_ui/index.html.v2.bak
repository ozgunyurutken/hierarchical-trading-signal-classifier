<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Signal Classifier</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>Crypto Signal Classifier</h1>
            <p class="subtitle">Three-Stage Hierarchical ML Pipeline · BBL514E Pattern Recognition</p>
        </header>

        <main>
            <!-- Date-based prediction (primary, demo-safe) -->
            <section class="card">
                <h2>Get Prediction by Date</h2>
                <p class="hint">Test set tarihleri (son %15 chronological). Pre-computed features → no internet needed.</p>
                <div class="input-group">
                    <label for="symbol-select">Symbol:</label>
                    <select id="symbol-select">
                        <option value="BTC">Bitcoin (BTC)</option>
                    </select>
                    <label for="date-select">Date:</label>
                    <select id="date-select">
                        <option value="">— loading dates —</option>
                    </select>
                    <label for="model-select">Model:</label>
                    <select id="model-select">
                        <option value="lda">LDA</option>
                        <option value="mlp">MLP</option>
                    </select>
                    <button id="predict-btn" onclick="getPredictionByDate()">Get Prediction</button>
                </div>
            </section>

            <!-- Live prediction (best-effort, requires internet) -->
            <section class="card">
                <h2>Live Prediction (yfinance)</h2>
                <p class="hint">Latest market data via yfinance. Internet bağlantısı gerekir; offline ise üstteki tarih dropdown'unu kullan.</p>
                <div class="input-group">
                    <button onclick="getLivePrediction()">Get Live Prediction</button>
                </div>
            </section>

            <!-- Result -->
            <section id="result-section" class="card hidden">
                <h2>Prediction Result <span id="result-meta" class="hint"></span></h2>
                <div class="signal-display">
                    <div id="signal-badge" class="signal-badge">
                        <span id="signal-text">--</span>
                    </div>
                    <div class="confidence-container">
                        <label>Confidence</label>
                        <div class="progress-bar">
                            <div id="confidence-bar" class="progress-fill"></div>
                        </div>
                        <span id="confidence-value">0%</span>
                    </div>
                </div>

                <div class="stage-breakdown">
                    <div class="stage-card">
                        <h3>Stage 1: Trend</h3>
                        <div id="trend-probs" class="prob-bars"></div>
                    </div>
                    <div class="stage-card">
                        <h3>Stage 2: Macro Regime</h3>
                        <div id="regime-probs" class="prob-bars"></div>
                    </div>
                    <div class="stage-card">
                        <h3>Stage 3: Signal</h3>
                        <div id="signal-probs" class="prob-bars"></div>
                    </div>
                </div>
            </section>

            <section id="error-section" class="card hidden error-card">
                <h2>Error</h2>
                <p id="error-message"></p>
            </section>

            <div id="loading" class="hidden">
                <div class="spinner"></div>
                <p>Computing prediction...</p>
            </div>
        </main>

        <footer>
            <p>BBL514E Pattern Recognition Term Project · 2026 · MVP build</p>
        </footer>
    </div>

    <script src="/static/app.js"></script>
</body>
</html>
