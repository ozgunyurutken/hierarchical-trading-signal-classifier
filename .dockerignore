# Virtual environment
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Notebooks (large + not needed at runtime)
notebooks/
.ipynb_checkpoints/

# Reports (figures, generated) — exclude all except files needed at runtime
reports/
!reports/Phase5.1_arch_ablation/v5_p5_arch_equity_curves_btc.csv
!reports/Phase5.1_arch_ablation/v5_p5_arch_equity_curves_eth.csv
!reports/Phase5.1_arch_ablation/v5_p5_arch_backtest_summary.csv

# Docs / project mgmt
*.md
!app/static/*.md  # keep any in static if used
PLAN.md
MEMORY.md
CLAUDE.md
*.pdf

# Data: only processed + labels needed at runtime
data/raw/
data/processed/btc_features_all.csv
data/processed/btc_adf_results.csv

# V2/V3/V4 legacy joblib models — V5 backend reads OOF CSV, not joblib.
# Keep V5 What-If final-fit bundles (used by /predict_custom).
